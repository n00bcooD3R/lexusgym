# Supabase (free tier: supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# WhatsApp - choose ONE option:

# Option A: Meta WhatsApp Cloud API (1000 free convos/month)
WA_PROVIDER=meta
META_WA_TOKEN=YOUR_PERMANENT_TOKEN
META_WA_PHONE_ID=YOUR_PHONE_NUMBER_ID

# Option B: whatsapp-web.js self-hosted bridge (free, uses your WA number)
# WA_PROVIDER=local
# LOCAL_WA_URL=http://localhost:3001
# LOCAL_WA_SECRET=changeme

# Cron secret (for /api/cron/reminders)
CRON_SECRET=changeme
