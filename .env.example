# Supabase (free tier: supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ── WhatsApp Provider ─────────────────────────────────────────────────────────
# Options: evolution (recommended) | meta | local | none

# Option A: Evolution API — Baileys engine, no Puppeteer, self-hosted on EC2 (RECOMMENDED)
# Setup: docker run -d -p 8080:8080 -e AUTHENTICATION_TYPE=apikey -e AUTHENTICATION_API_KEY=your-key atendai/evolution-api:latest
# Then create instance + scan QR at http://<ip>:8080/instance/connect/gymapp
WA_PROVIDER=evolution
EVOLUTION_API_URL=http://YOUR-EC2-IP:8080
EVOLUTION_API_KEY=YOUR_EVOLUTION_API_KEY
EVOLUTION_INSTANCE=gymapp

# Option B: Meta WhatsApp Cloud API (1000 free convos/month, needs Meta Business approval)
# WA_PROVIDER=meta
# META_WA_TOKEN=YOUR_PERMANENT_TOKEN
# META_WA_PHONE_ID=YOUR_PHONE_NUMBER_ID

# Option C: whatsapp-web.js local bridge (legacy, Puppeteer-based, RAM heavy)
# WA_PROVIDER=local
# LOCAL_WA_URL=http://localhost:3001
# LOCAL_WA_SECRET=changeme

# Cron secret (for /api/cron/reminders)
CRON_SECRET=changeme

# ── Biometric Integration (eSSL / ZKTeco) ───────────────────────────────────
# Method 1 & 2: Local SQL Server Database Sync Agent (eTimeTrackLite)
ESSL_DB_SERVER=LOCALHOST\\SQLEXPRESS
ESSL_DB_NAME=eTimeTrackLite1
ESSL_DB_USER=
ESSL_DB_PASS=

# Method 3: Direct Socket connection to Device (ZK / eSSL)
ZK_DEVICE_IP=192.168.1.201
ZK_DEVICE_PORT=4370
ZK_FORCE_UDP=False
ZK_COMM_KEY=0
