{
  "builds": [
    { "src": "backend/api/index.py", "use": "@vercel/python" },
    { "src": "web/package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/api/index.py" },
    { "src": "/assets/(.*)", "dest": "web/assets/$1" },
    { "src": "/logo.png", "dest": "web/logo.png" },
    { "src": "/paid-seal.png", "dest": "web/paid-seal.png" },
    { "src": "/whatsapp-qr.png", "dest": "web/whatsapp-qr.png" },
    { "src": "/favicon.ico", "dest": "web/favicon.ico" },
    { "src": "/(.*)", "dest": "web/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/reminders", "schedule": "0 4 * * *" }
  ]
}
